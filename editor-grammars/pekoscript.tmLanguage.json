{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Peko",
  "scopeName": "source.peko",
  "patterns": [
    {
      "include": "#main"
    }
  ],
  "repository": {
    "main": {
      "patterns": [
        {
          "include": "#comments"
        },
        {
          "include": "#declarations"
        },
        {
          "include": "#keywords"
        },
        {
          "include": "#primitive-types"
        },
        {
          "include": "#visibility"
        },
        {
          "include": "#operator-overload"
        },
        {
          "include": "#protected-string"
        },
        {
          "include": "#format-string"
        },
        {
          "include": "#double-string"
        },
        {
          "include": "#char"
        },
        {
          "include": "#numbers"
        },
        {
          "include": "#array-literal"
        },
        {
          "include": "#map-literal"
        },
        {
          "include": "#cast"
        },
        {
          "include": "#xml-element"
        },
        {
          "include": "#generic-arguments"
        },
        {
          "include": "#function-call"
        },
        {
          "include": "#brace-block"
        },
        {
          "include": "#operators"
        },
        {
          "include": "#punctuation"
        },
        {
          "include": "#identifiers"
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "include": "#doc-comment-example"
        },
        {
          "include": "#doc-comment-tag"
        },
        {
          "include": "#doc-comment-line"
        },
        {
          "include": "#module-doc-comment"
        },
        {
          "include": "#line-comment"
        }
      ]
    },
    "doc-comment-example": {
      "begin": "(///)\\s*(@example)\\s*(\\{)",
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.comment.peko"
        },
        "2": {
          "name": "keyword.other.documentation.peko"
        },
        "3": {
          "name": "punctuation.section.block.begin.peko"
        }
      },
      "end": "\\}",
      "endCaptures": {
        "0": {
          "name": "punctuation.section.block.end.peko"
        }
      },
      "patterns": [
        {
          "match": "^\\s*(///)",
          "captures": {
            "1": {
              "name": "punctuation.definition.comment.peko"
            }
          }
        },
        {
          "include": "$self"
        }
      ]
    },
    "doc-comment-tag": {
      "match": "(///)\\s*(@(?:param|example))\\b[ \\t]*([A-Za-z_$][A-Za-z0-9_$]*)?(.*)$",
      "captures": {
        "1": {
          "name": "punctuation.definition.comment.peko"
        },
        "2": {
          "name": "keyword.other.documentation.peko"
        },
        "3": {
          "name": "variable.parameter.peko"
        },
        "4": {
          "name": "comment.line.documentation.peko"
        }
      }
    },
    "doc-comment-line": {
      "match": "(///).*$",
      "name": "comment.line.documentation.peko",
      "captures": {
        "1": {
          "name": "punctuation.definition.comment.peko"
        }
      }
    },
    "module-doc-comment": {
      "match": "(//!).*$",
      "name": "comment.line.documentation.module.peko",
      "captures": {
        "1": {
          "name": "punctuation.definition.comment.peko"
        }
      }
    },
    "line-comment": {
      "match": "(//).*$",
      "name": "comment.line.double-slash.peko",
      "captures": {
        "1": {
          "name": "punctuation.definition.comment.peko"
        }
      }
    },
    "string-escapes": {
      "patterns": [
        {
          "match": "\\\\(x[0-9A-Fa-f]{2}|u\\{[0-9A-Fa-f]+\\}|[nrt\\\\\\'\"`0])",
          "name": "constant.character.escape.peko"
        }
      ]
    },
    "double-string": {
      "name": "string.quoted.double.peko",
      "begin": "\"",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.string.begin.peko"
        }
      },
      "end": "\"",
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.string.end.peko"
        }
      },
      "patterns": [
        {
          "include": "#string-escapes"
        }
      ]
    },
    "protected-string": {
      "name": "string.quoted.double.protected.peko",
      "begin": "#\"",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.string.begin.peko"
        }
      },
      "end": "\"",
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.string.end.peko"
        }
      },
      "patterns": [
        {
          "include": "#string-escapes"
        }
      ]
    },
    "char": {
      "name": "string.quoted.single.peko",
      "begin": "'",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.string.begin.peko"
        }
      },
      "end": "'",
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.string.end.peko"
        }
      },
      "patterns": [
        {
          "include": "#string-escapes"
        }
      ]
    },
    "format-string": {
      "name": "string.template.peko",
      "begin": "`",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.string.begin.peko"
        }
      },
      "end": "`",
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.string.end.peko"
        }
      },
      "patterns": [
        {
          "include": "#string-escapes"
        },
        {
          "include": "#interpolation"
        }
      ]
    },
    "interpolation": {
      "name": "meta.interpolation.peko",
      "begin": "\\$\\{",
      "beginCaptures": {
        "0": {
          "name": "punctuation.section.interpolation.begin.peko"
        }
      },
      "end": "\\}",
      "endCaptures": {
        "0": {
          "name": "punctuation.section.interpolation.end.peko"
        }
      },
      "patterns": [
        {
          "include": "$self"
        }
      ]
    },
    "numbers": {
      "match": "\\b[0-9][0-9_]*(?:\\.[0-9][0-9_]*)?\\b",
      "name": "constant.numeric.peko"
    },
    "array-literal": {
      "begin": "(#)(\\[)",
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.array.peko"
        },
        "2": {
          "name": "punctuation.section.brackets.begin.peko"
        }
      },
      "end": "\\]",
      "endCaptures": {
        "0": {
          "name": "punctuation.section.brackets.end.peko"
        }
      },
      "patterns": [
        {
          "include": "$self"
        }
      ]
    },
    "map-literal": {
      "begin": "(#)(\\{)",
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.map.peko"
        },
        "2": {
          "name": "punctuation.section.braces.begin.peko"
        }
      },
      "end": "\\}",
      "endCaptures": {
        "0": {
          "name": "punctuation.section.braces.end.peko"
        }
      },
      "patterns": [
        {
          "include": "$self"
        }
      ]
    },
    "brace-block": {
      "begin": "\\{",
      "beginCaptures": {
        "0": {
          "name": "punctuation.section.braces.begin.peko"
        }
      },
      "end": "\\}",
      "endCaptures": {
        "0": {
          "name": "punctuation.section.braces.end.peko"
        }
      },
      "patterns": [
        {
          "include": "$self"
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "match": "\\b(fn)\\s+([A-Za-z_$][A-Za-z0-9_$]*)",
          "captures": {
            "1": {
              "name": "keyword.other.peko"
            },
            "2": {
              "name": "entity.name.function.peko"
            }
          }
        },
        {
          "match": "\\b(class)\\s+([A-Za-z_$][A-Za-z0-9_$]*)",
          "captures": {
            "1": {
              "name": "keyword.other.peko"
            },
            "2": {
              "name": "entity.name.type.class.peko"
            }
          }
        },
        {
          "match": "\\b(trait)\\s+([A-Za-z_$][A-Za-z0-9_$]*)",
          "captures": {
            "1": {
              "name": "keyword.other.peko"
            },
            "2": {
              "name": "entity.name.type.trait.peko"
            }
          }
        },
        {
          "match": "\\b(enum)\\s+([A-Za-z_$][A-Za-z0-9_$]*)",
          "captures": {
            "1": {
              "name": "keyword.other.peko"
            },
            "2": {
              "name": "entity.name.type.enum.peko"
            }
          }
        },
        {
          "match": "\\b(module)\\s+([A-Za-z_$][A-Za-z0-9_$]*)",
          "captures": {
            "1": {
              "name": "keyword.other.peko"
            },
            "2": {
              "name": "entity.name.namespace.peko"
            }
          }
        },
        {
          "match": "\\b(platform|arch)\\s+([A-Za-z_$][A-Za-z0-9_$]*)",
          "captures": {
            "1": {
              "name": "keyword.control.peko"
            },
            "2": {
              "name": "entity.name.namespace.peko"
            }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "match": "\\b(if|else|for|while|in|return|break|continue|switch|halt)\\b",
          "name": "keyword.control.peko"
        },
        {
          "match": "\\b(import|from|as|style|link|platform|arch)\\b",
          "name": "keyword.control.import.peko"
        },
        {
          "match": "\\b(fn|class|trait|enum|impl|module|closure|constructor|operator|super|new|let|const|constant|danger_cast|state|Args)\\b",
          "name": "keyword.other.peko"
        },
        {
          "match": "\\b(true|false|null|None)\\b",
          "name": "constant.language.peko"
        },
        {
          "match": "\\b(this|self|Self)\\b",
          "name": "variable.language.peko"
        }
      ]
    },
    "primitive-types": {
      "match": "\\b(?:i1|i8|i16|i32|i64|i128|f16|f32|f64|number|cstr|opaque|void|pointer|string|bool|char)\\b",
      "name": "storage.type.builtin.peko"
    },
    "visibility": {
      "begin": "(\\[)(?=\\s*(?:public|private|mutates|static|serial|external|notrack|gcsafe|constant|state|variadic|blockexit|hide)\\b)",
      "beginCaptures": {
        "1": {
          "name": "punctuation.section.brackets.begin.peko"
        }
      },
      "end": "\\]",
      "endCaptures": {
        "0": {
          "name": "punctuation.section.brackets.end.peko"
        }
      },
      "patterns": [
        {
          "match": "\\b(?:public|private|mutates|static|serial|external|notrack|gcsafe|constant|state|variadic|blockexit|hide)\\b",
          "name": "storage.modifier.peko"
        }
      ]
    },
    "operator-overload": {
      "begin": "(\\[)\\s*(operator)\\b",
      "beginCaptures": {
        "1": {
          "name": "punctuation.section.brackets.begin.peko"
        },
        "2": {
          "name": "keyword.other.peko"
        }
      },
      "end": "\\]",
      "endCaptures": {
        "0": {
          "name": "punctuation.section.brackets.end.peko"
        }
      },
      "patterns": [
        {
          "match": "[^\\]\\s]+",
          "name": "entity.name.function.operator.peko"
        }
      ]
    },
    "cast": {
      "begin": "\\b(as)\\s+",
      "beginCaptures": {
        "1": {
          "name": "keyword.control.peko"
        }
      },
      "end": "(?=[\\s;,)\\]}=<>+\\-*/%^&!?|]|$)",
      "patterns": [
        {
          "include": "#type"
        }
      ]
    },
    "type": {
      "patterns": [
        {
          "match": "\\b(?:i128|i64|i32|i16|i8|i1|f64|f32|f16|cstr|opaque|void|pointer|number|string|bool|char)\\b",
          "name": "storage.type.builtin.peko"
        },
        {
          "match": "\\bclosure\\b",
          "name": "keyword.other.peko"
        },
        {
          "match": "[&?]|\\[\\]",
          "name": "keyword.operator.type.peko"
        },
        {
          "match": "::",
          "name": "punctuation.delimiter.peko"
        },
        {
          "match": ",",
          "name": "punctuation.delimiter.peko"
        },
        {
          "include": "#type-arguments"
        },
        {
          "match": "[A-Za-z_$][A-Za-z0-9_$]*",
          "name": "entity.name.type.peko"
        }
      ]
    },
    "type-arguments": {
      "begin": "<",
      "beginCaptures": {
        "0": {
          "name": "punctuation.definition.typeparameters.begin.peko"
        }
      },
      "end": ">",
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.typeparameters.end.peko"
        }
      },
      "patterns": [
        {
          "include": "#type"
        }
      ]
    },
    "generic-arguments": {
      "begin": "(<)(?=[\\w$\\s,&:?\\[\\]<>]*>\\s*\\()",
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.typeparameters.begin.peko"
        }
      },
      "end": ">",
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.typeparameters.end.peko"
        }
      },
      "patterns": [
        {
          "include": "#type"
        }
      ]
    },
    "function-call": {
      "match": "([A-Za-z_$][A-Za-z0-9_$]*)\\s*(?=\\(|<[\\w$\\s,&:?\\[\\]<>]*>\\s*\\()",
      "captures": {
        "1": {
          "name": "entity.name.function.call.peko"
        }
      }
    },
    "xml-element": {
      "begin": "(<)((?:blockquote|figcaption|basefont|colgroup|datalist|fieldset|frameset|menuitem|noscript|optgroup|progress|template|textarea|acronym|address|article|bgsound|caption|details|isindex|marquee|noembed|section|summary|applet|button|canvas|center|dialog|figure|footer|header|hgroup|iframe|keygen|legend|object|option|output|script|source|spacer|strike|strong|aside|audio|embed|frame|input|label|meter|param|small|table|tbody|tfoot|title|track|video|abbr|area|base|body|cite|code|data|font|form|head|html|main|mark|meta|nobr|ruby|samp|span|time|bdi|bdo|big|col|del|dfn|dir|div|img|ins|kbd|nav|pre|sub|sup|svg|var|wbr|xmp|br|dd|dl|dt|em|h1|h2|h3|h4|h5|h6|hr|li|rp|rt|td|tr|tt|a|b|i|p|q|u))(?![\\w$])",
      "beginCaptures": {
        "1": {
          "name": "punctuation.definition.tag.begin.peko"
        },
        "2": {
          "name": "entity.name.tag.peko"
        }
      },
      "end": "(/>)|(</)((?:blockquote|figcaption|basefont|colgroup|datalist|fieldset|frameset|menuitem|noscript|optgroup|progress|template|textarea|acronym|address|article|bgsound|caption|details|isindex|marquee|noembed|section|summary|applet|button|canvas|center|dialog|figure|footer|header|hgroup|iframe|keygen|legend|object|option|output|script|source|spacer|strike|strong|aside|audio|embed|frame|input|label|meter|param|small|table|tbody|tfoot|title|track|video|abbr|area|base|body|cite|code|data|font|form|head|html|main|mark|meta|nobr|ruby|samp|span|time|bdi|bdo|big|col|del|dfn|dir|div|img|ins|kbd|nav|pre|sub|sup|svg|var|wbr|xmp|br|dd|dl|dt|em|h1|h2|h3|h4|h5|h6|hr|li|rp|rt|td|tr|tt|a|b|i|p|q|u))\\s*(>)",
      "endCaptures": {
        "1": {
          "name": "punctuation.definition.tag.end.peko"
        },
        "2": {
          "name": "punctuation.definition.tag.begin.peko"
        },
        "3": {
          "name": "entity.name.tag.peko"
        },
        "4": {
          "name": "punctuation.definition.tag.end.peko"
        }
      },
      "patterns": [
        {
          "include": "#xml-attribute"
        },
        {
          "match": ">",
          "name": "punctuation.definition.tag.end.peko"
        },
        {
          "include": "#xml-value-interpolation"
        },
        {
          "include": "#xml-element-interpolation"
        },
        {
          "include": "#xml-element"
        },
        {
          "match": "\\s+"
        },
        {
          "include": "#xml-text"
        }
      ]
    },
    "xml-attribute": {
      "patterns": [
        {
          "begin": "([A-Za-z_$][A-Za-z0-9_$]*)\\s*(=)\\s*(?=\\{)",
          "beginCaptures": {
            "1": {
              "name": "entity.other.attribute-name.peko"
            },
            "2": {
              "name": "keyword.operator.assignment.peko"
            }
          },
          "end": "(?<=\\})",
          "patterns": [
            {
              "include": "#brace-block"
            }
          ]
        },
        {
          "begin": "([A-Za-z_$][A-Za-z0-9_$]*)\\s*(=)\\s*(?=[\\\"`]|#\\\")",
          "beginCaptures": {
            "1": {
              "name": "entity.other.attribute-name.peko"
            },
            "2": {
              "name": "keyword.operator.assignment.peko"
            }
          },
          "end": "(?<=[\\\"`])",
          "patterns": [
            {
              "include": "#protected-string"
            },
            {
              "include": "#format-string"
            },
            {
              "include": "#double-string"
            }
          ]
        },
        {
          "match": "([A-Za-z_$][A-Za-z0-9_$]*)\\s*(=)\\s*([^\\s>]+)?",
          "captures": {
            "1": {
              "name": "entity.other.attribute-name.peko"
            },
            "2": {
              "name": "keyword.operator.assignment.peko"
            },
            "3": {
              "patterns": [
                {
                  "include": "#main"
                }
              ]
            }
          }
        }
      ]
    },
    "xml-value-interpolation": {
      "name": "meta.interpolation.peko",
      "begin": "\\$\\{",
      "beginCaptures": {
        "0": {
          "name": "punctuation.section.interpolation.begin.peko"
        }
      },
      "end": "\\}",
      "endCaptures": {
        "0": {
          "name": "punctuation.section.interpolation.end.peko"
        }
      },
      "patterns": [
        {
          "include": "$self"
        }
      ]
    },
    "xml-element-interpolation": {
      "name": "meta.interpolation.element.peko",
      "begin": "\\{",
      "beginCaptures": {
        "0": {
          "name": "punctuation.section.interpolation.begin.peko"
        }
      },
      "end": "\\}",
      "endCaptures": {
        "0": {
          "name": "punctuation.section.interpolation.end.peko"
        }
      },
      "patterns": [
        {
          "include": "$self"
        }
      ]
    },
    "xml-text": {
      "match": "[^<>{}$]+|\\$",
      "name": "text.peko"
    },
    "operators": {
      "patterns": [
        {
          "match": "(<=|>=|==|!=|&&|\\|\\||\\.\\.|=>|:=)",
          "name": "keyword.operator.peko"
        },
        {
          "match": "(\\^|%|\\+|\\-|\\*|/|<|>|=|!|&|\\?|\\bas\\b)",
          "name": "keyword.operator.peko"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "match": "::",
          "name": "punctuation.delimiter.scope.peko"
        },
        {
          "match": "\\.",
          "name": "punctuation.delimiter.peko"
        },
        {
          "match": ",",
          "name": "punctuation.delimiter.peko"
        },
        {
          "match": ":",
          "name": "punctuation.delimiter.peko"
        },
        {
          "match": ";",
          "name": "punctuation.terminator.peko"
        },
        {
          "match": "@",
          "name": "punctuation.definition.version.peko"
        },
        {
          "match": "[()]",
          "name": "punctuation.section.parens.peko"
        },
        {
          "match": "[\\[\\]]",
          "name": "punctuation.section.brackets.peko"
        }
      ]
    },
    "identifiers": {
      "match": "[A-Za-z_$][A-Za-z0-9_$]*",
      "name": "variable.other.peko"
    }
  }
}
