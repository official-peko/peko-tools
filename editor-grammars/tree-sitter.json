{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "pekoscript",
      "camelcase": "Pekoscript",
      "title": "Pekoscript",
      "scope": "source.pekoscript",
      "file-types": [
        "peko"
      ],
      "injection-regex": "^pekoscript$",
      "class-name": "TreeSitterPekoscript"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Pekoscript grammar for tree-sitter",
    "authors": [
      {
        "name": "Preston Brown",
        "email": "preston@pekoui.com",
        "url": "https://pekoui.com"
      }
    ],
    "links": {
      "repository": "https://github.com/official-peko/peko-tools",
      "funding": ""
    }
  },
  "bindings": {
    "c": false,
    "go": false,
    "java": false,
    "node": false,
    "python": false,
    "rust": false,
    "swift": false,
    "zig": false
  }
}